{
  "name": "sp2-resit",
  "version": "1.0.0",
  "description": "SP2 Resit Auction Site using Tailwind and SCSS",
  "main": "index.js",
  "scripts": {
    "build:sass": "sass css/main.scss css/styles.css",
    "watch:sass": "sass css/main.scss css/styles.css --watch",
    "build:tailwind": "postcss css/styles.css -o css/output.css",
    "watch:tailwind": "postcss css/styles.css -o css/output.css --watch",
    "dev": "concurrently \"npm run watch:sass\" \"npm run watch:tailwind\"",
    "build": "npm run build:sass && npm run build:tailwind"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "autoprefixer": "^10.4.27",
    "concurrently": "^9.0.1",
    "postcss": "^8.5.8",
    "postcss-cli": "^11.0.0",
    "sass": "^1.98.0",
    "tailwindcss": "^3.4.10"
  },
  "dependencies": {
    "baseline-browser-mapping": "^2.10.8",
    "browserslist": "^4.28.1",
    "caniuse-lite": "^1.0.30001780",
    "chokidar": "^4.0.3",
    "detect-libc": "^2.1.2",
    "electron-to-chromium": "^1.5.313",
    "escalade": "^3.2.0",
    "fraction.js": "^5.3.4",
    "immutable": "^5.1.5",
    "is-extglob": "^2.1.1",
    "is-glob": "^4.0.3",
    "nanoid": "^3.3.11",
    "node-addon-api": "^7.1.1",
    "node-releases": "^2.0.36",
    "picocolors": "^1.1.1",
    "picomatch": "^4.0.3",
    "postcss-value-parser": "^4.2.0",
    "readdirp": "^4.1.2",
    "source-map-js": "^1.2.1",
    "update-browserslist-db": "^1.2.3"
  }
}
